 from dataclass_wizard import JSONSerializable  # Або стандартний dataclass
from dataclasses import dataclass, field
from enum import Enum
import pickle
import csv
import json

class Currency(Enum):
    UAH = "UAH"
    USD = "USD"
    EUR = "EUR"

@dataclass
class User:
    username: str
    email: str

@dataclass
class ExpenseRecord:
    description: str
    payer: User
    total_amount: float
    currency: Currency
    participants: list[User] = field(default_factory=list)

    def calculate_user_share(self, user: User) -> float:
        raise NotImplementedError("Цей метод має бути перевизначений у класах-нащадках")

class EqualSplit(ExpenseRecord):
    """Поділ витрат порівну між усіма учасниками"""
    def calculate_user_share(self, user: User) -> float:
        if user not in self.participants and user != self.payer:
            return 0.0
        # Ділимо загальну суму порівну на кількість учасників
        return self.total_amount / max(len(self.participants), 1)

class PercentageSplit(ExpenseRecord):
    """Поділ витрат відповідно до відсоткових часток"""
    def init(self, description, payer, total_amount, currency, participants, percentages: dict[str, float]):
        super().init(description, payer, total_amount, currency, participants)
        self.percentages = percentages  # Словник вигляду {username: відсоток_від_1_до_100}

    def calculate_user_share(self, user: User) -> float:
        if user not in self.participants:
            return 0.0
        user_percentage = self.percentages.get(user.username, 0.0)
        return (self.total_amount * user_percentage) / 100.0

class GroupLedger:
    def init(self):
        self._expenses = []  # Колекція об'єктів ExpenseRecord для консервації
        self.config = {}     # Словник для зовнішніх налаштувань

    def add_expense(self, expense: ExpenseRecord):
        self._expenses.append(expense)

    def show_ledger(self):
        if not self._expenses:
            print("Журнал витрат порожній.")
            return
        print(f"\n--- Журнал витрат компанії / групи: {self.config.get('group_name', 'Default Group')} ---")
        for exp in self._expenses:
            exp_type = "Рівні частини" if isinstance(exp, EqualSplit) else "Відсоткові частки"
            print(f"- {exp.description} [{exp_type}] | Платник: {exp.payer.username} | Сума: {exp.total_amount} {exp.currency.value}")

    # Завдання «Зовнішні налаштування» (JSON)
    def load_config(self, filepath="config.json"):
        try:
            with open(filepath, 'r', encoding='utf-8') as f:
                self.config = json.load(f)
            print(f"[System] Налаштування успішно завантажено з JSON для групи: {self.config.get('group_name', 'Незв.')}")
        except FileNotFoundError:
            print("[Error] Файл конфігурації JSON не знайдено. Застосовано дефолтні ліміти.")
            self.config = {"group_name": "Local Group", "max_records_per_page": 10}

    # Завдання «Повний бекап системи» (Pickle)
    def save_system_state(self, filepath="system.pkl"):
        with open(filepath, 'wb') as f:
            pickle.dump(self._expenses, f)
        print("[System] Усі об'єкти витрат (стан взаєморозрахунків) успішно законсервовано в бінарний файл (Pickle).")

    def load_system_state(self, filepath="system.pkl"):
        try:
            with open(filepath, 'rb') as f:
                self._expenses = pickle.load(f)
            print(f"[System] Стан системи успішно відновлено. Завантажено записів про витрати: {len(self._expenses)}")
        except FileNotFoundError:
            print("[Error] Файл резервної копії Pickle не знайдено. Ініціалізовано нову порожню сесію.")
 # Завдання «Табличний звіт» (CSV)
    def export_transactions_report(self, filepath="transactions_report.csv"):
        with open(filepath, 'w', newline='', encoding='utf-16') as f:
            writer = csv.writer(f, delimiter='\t')
            # Заголовки плоскої таблиці транзакцій
            writer.writerow(['Опис витрати', 'Тип розподілу', 'Хто оплатив', 'Загальна сума', 'Валюта', 'Кількість учасників'])
            
            for exp in self._expenses:
                exp_type = "Equal" if isinstance(exp, EqualSplit) else "Percentage"
                writer.writerow([
                    exp.description,
                    exp_type,
                    exp.payer.username,
                    exp.total_amount,
                    exp.currency.value,
                    len(exp.participants)
                ])
        print(f"[System] Звіт про витрати успішно експортовано у табличний CSV: {filepath}")

